<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        style="@style/PureShield.Toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💬"
                android:textSize="40sp"
                android:textColor="@color/green_light"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your feedback helps improve PureShield for everyone."
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="24dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/PureShield.Card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <Button
                        android:id="@+id/btnRate"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="⭐  Rate on Play Store"
                        android:textAlignment="textStart"
                        android:gravity="start|center_vertical"
                        android:paddingStart="20dp"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/surface_variant"
                        android:layout_marginStart="16dp" android:layout_marginEnd="16dp" />

                    <Button
                        android:id="@+id/btnBug"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="🐛  Report a Bug"
                        android:textAlignment="textStart"
                        android:gravity="start|center_vertical"
                        android:paddingStart="20dp"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/surface_variant"
                        android:layout_marginStart="16dp" android:layout_marginEnd="16dp" />

                    <Button
                        android:id="@+id/btnFeature"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="💡  Suggest a Feature"
                        android:textAlignment="textStart"
                        android:gravity="start|center_vertical"
                        android:paddingStart="20dp"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/surface_variant"
                        android:layout_marginStart="16dp" android:layout_marginEnd="16dp" />

                    <Button
                        android:id="@+id/btnEmail"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="📧  Email Developer"
                        android:textAlignment="textStart"
                        android:gravity="start|center_vertical"
                        android:paddingStart="20dp"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bug reports and feature suggestions go to GitHub Issues.\nYour ideas matter — JazakAllah khayran."
                android:textSize="12sp"
                android:textColor="@color/text_hint"
                android:lineSpacingMultiplier="1.5"
                android:textAlignment="center"
                android:layout_marginTop="20dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="وَفِّقْنَا لِمَا تُحِبُّ وَتَرْضَى"
                android:textSize="13sp"
                android:textColor="@color/green_dark"
                android:fontFamily="serif"
                android:textAlignment="center"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="6dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
