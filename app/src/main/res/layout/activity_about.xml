<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        style="@style/PureShield.Toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <!-- App icon + name -->
            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:contentDescription="TODO"
                android:src="@mipmap/ic_launcher"
                android:layout_marginTop="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/green"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/about_version"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✦ ✦ ✦"
                android:textSize="14sp"
                android:textColor="@color/green_dark"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="20dp" />

            <!-- Description card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/PureShield.Card"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:id="@+id/tvDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:lineSpacingMultiplier="1.6"
                        android:textAlignment="center" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Privacy badges card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/PureShield.Card"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/about_no_internet" android:textColor="@color/active_green"
                        android:textSize="13sp" android:layout_marginBottom="8dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/about_no_data" android:textColor="@color/active_green"
                        android:textSize="13sp" android:layout_marginBottom="8dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/about_no_ads" android:textColor="@color/active_green"
                        android:textSize="13sp" android:layout_marginBottom="8dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/about_free" android:textColor="@color/active_green"
                        android:textSize="13sp" android:layout_marginBottom="8dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/about_privacy" android:textColor="@color/active_green"
                        android:textSize="13sp" />
                    

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Developer section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DEVELOPER"
                style="@style/PureShield.SectionTitle"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/PureShield.Card"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="@string/about_developer"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="Innovating Beyond Limits in Software &amp; Technology"
                        android:textAlignment="center"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/btnGithub"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:text="@string/about_website"
                        style="@style/PureShield.Button.Outline"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/btnPrivacyPolicy"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginTop="10dp"
                        android:text="@string/about_privacy_policy"
                        style="@style/PureShield.Button.Outline"
                        android:textSize="12sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- License -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/about_license"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Accessibility is used only for user-enabled blocking on this device."
                android:textSize="11sp"
                android:textAlignment="center"
                android:textColor="@color/text_hint"
                android:layout_marginBottom="8dp" />

            <!-- Islamic footer -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="جَزَاكَ اللَّهُ خَيْرًا"
                android:textSize="16sp"
                android:textColor="@color/green_dark"
                android:fontFamily="serif"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="May Allah reward you with good"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
