<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        style="@style/PureShield.Toolbar" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <!-- Shield icon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔐"
            android:textSize="48sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvPinTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Set Protection PIN"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/green"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvPinSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose a 4-digit PIN"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="32dp" />

        <!-- PIN dots display -->
        <TextView
            android:id="@+id/tvPinDots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="○ ○ ○ ○"
            android:textSize="32sp"
            android:textColor="@color/green"
            android:letterSpacing="0.3"
            android:layout_marginBottom="32dp" />

        <!-- Hidden input (backing field) -->
        <EditText
            android:id="@+id/etPin"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            android:inputType="numberPassword" />

        <!-- Numpad -->
        <GridLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:rowCount="4"
            android:layout_marginBottom="16dp">

            <!-- Row 1: 1 2 3 -->
            <Button android:id="@+id/btn1" android:text="1" style="@style/PinButton" />
            <Button android:id="@+id/btn2" android:text="2" style="@style/PinButton" />
            <Button android:id="@+id/btn3" android:text="3" style="@style/PinButton" />

            <!-- Row 2: 4 5 6 -->
            <Button android:id="@+id/btn4" android:text="4" style="@style/PinButton" />
            <Button android:id="@+id/btn5" android:text="5" style="@style/PinButton" />
            <Button android:id="@+id/btn6" android:text="6" style="@style/PinButton" />

            <!-- Row 3: 7 8 9 -->
            <Button android:id="@+id/btn7" android:text="7" style="@style/PinButton" />
            <Button android:id="@+id/btn8" android:text="8" style="@style/PinButton" />
            <Button android:id="@+id/btn9" android:text="9" style="@style/PinButton" />

            <!-- Row 4: Delete 0 Confirm -->
            <Button android:id="@+id/btnDelete" android:text="⌫" style="@style/PinButton" />
            <Button android:id="@+id/btn0" android:text="0" style="@style/PinButton" />
            <Button android:id="@+id/btnConfirm" android:text="✓"
                android:backgroundTint="@color/secondary"
                style="@style/PinButton" />

        </GridLayout>

    </LinearLayout>
</LinearLayout>
