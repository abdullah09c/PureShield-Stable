    <string name="accessibility_disclosure_title">Enable Accessibility Control</string>
    <string name="accessibility_disclosure_msg">PureShield needs Accessibility Service to detect the active screen inside supported apps and block the short-form feeds you selected. It works locally on your device and does not send your screen data anywhere.</string>
    <string name="device_admin_disclosure_title">Enable Uninstall Protection</string>
    <string name="device_admin_disclosure_msg">PureShield uses Device Admin only to prevent impulsive uninstallation from this device. You can still disable it later with your PIN.</string>

