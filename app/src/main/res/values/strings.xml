    <!-- Service -->
    <string name="service_label">PureShield</string>
    <string name="service_description">PureShield uses Accessibility Service only to detect supported distraction screens (like Shorts, Reels, and TikTok) and block them locally on your device.\n\nPrivacy First: PureShield does NOT collect, store, or share personal data, and it does not have internet access.</string>
